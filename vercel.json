{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-reminder",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/pending-reminder",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/pending-summary",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/pending-summary",
      "schedule": "30 10 * * *"
    }
  ]
}