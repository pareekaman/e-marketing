# ══════════════════════════════════════════════════════
# E-MARKETING TASK MANAGER — Environment Variables
# Local dev: copy this file to .env and fill in values
# Vercel: add these in Project Settings → Environment Variables
# ══════════════════════════════════════════════════════

# ── MySQL Database (Aiven / Railway / PlanetScale / etc.) ─────
DB_HOST=your-mysql-host.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=emarketing_task_manager
DB_PORT=3306
# Set to "true" if your MySQL provider requires SSL (Aiven, PlanetScale do)
DB_SSL=true

# ── App ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
APP_URL=https://your-vercel-app.vercel.app

# ── Gmail SMTP (for delegation task emails) ────────────
# 1. Enable 2FA on your Gmail
# 2. Generate App Password at https://myaccount.google.com/apppasswords
# 3. Paste 16-char password below WITHOUT spaces
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM_NAME=E-Marketing Task Manager

# ── Google Sheets API (service account JSON, single-line) ──────
# Take the entire contents of your credentials.json file,
# minify it to a single line, and paste below.
# (Keep the surrounding single-quotes if pasting in Vercel UI it auto-handles.)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
