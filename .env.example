# ══════════════════════════════════════════════════════
# E-MARKETING TASK MANAGER — Environment Variables
# Local dev: copy this file to .env and fill in values
# Vercel: add these in Project Settings → Environment Variables
# ══════════════════════════════════════════════════════

# ── MySQL Database (Aiven / Railway / PlanetScale / etc.) ─────
DB_HOST=your-mysql-host.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=emarketing_task_manager
DB_PORT=3306
# Set to "true" if your MySQL provider requires SSL (Aiven, PlanetScale do)
DB_SSL=true

# ── App ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
APP_URL=https://your-vercel-app.vercel.app

# ── Gmail SMTP (for delegation task emails) ────────────
# 1. Enable 2FA on your Gmail
# 2. Generate App Password at https://myaccount.google.com/apppasswords
# 3. Paste 16-char password below WITHOUT spaces
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM_NAME=E-Marketing Task Manager

# ── Google Sheets API (service account JSON, single-line) ──────
# Take the entire contents of your credentials.json file,
# minify it to a single line, and paste below.
# (Keep the surrounding single-quotes if pasting in Vercel UI it auto-handles.)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# ── DMS — Google Drive (OAuth 2.0, dedicated account) ─────────────────
# Uses a dedicated Gmail / Google Workspace account. One-time setup:
#
# 1. Go to console.cloud.google.com → New Project → "Company DMS"
# 2. APIs & Services → Library → enable "Google Drive API"
# 3. APIs & Services → OAuth consent screen → External → fill name + email
#    → Add scope: .../auth/drive → Publish to Production
# 4. Credentials → Create Credentials → OAuth client ID → Web application
#    → Authorised redirect URI: https://YOUR_APP_URL/api/google/callback
# 5. Copy Client ID and Client Secret below
# 6. Deploy, then visit https://YOUR_APP_URL/api/google/auth while logged in as admin
#    → Approve access → refresh token is saved automatically in the DB
# 7. Create a folder in the dedicated Google Drive, share it with yourself,
#    copy the folder ID from the URL and paste as GOOGLE_DRIVE_ROOT_FOLDER_ID

GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# Optional: set this if you got the refresh token manually (overrides DB value)
GOOGLE_OAUTH_REFRESH_TOKEN=

# The Google Drive folder ID where all client folders will be created.
# Create a folder in the dedicated account's Drive, copy ID from the URL:
# drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id_here

# ── Credit Cards — PDF Scanner (Flask + OpenAI) ────────
# Your OpenAI API key (starts with sk-)
OPENAI_API_KEY=sk-...your-openai-key...
# Flask PDF extractor URL (run: python app.py  → default port 5000)
FLASK_URL=http://localhost:5000/api/extract
# Model used by Flask for OCR — gpt-4.1-mini is fastest & cheapest
OPENAI_MODEL=gpt-4.1-mini
